generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rarity {
  common
  rare
  epic
  legendary
}

enum MissionStatus {
  COMPLETE
  ACTIVE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model Profile {
  id         Int     @id @default(1)
  name       String
  classRole  String
  roles      String[]
  tagline    String
  bio        String
  level      Int     @default(1)
  rank       String
  region     String
  email      String
  xpCurrent  Int     @default(0)
  xpMax      Int     @default(10000)
  avatarUrl  String?
}

model Stat {
  id    String @id @default(cuid())
  label String
  value Int
  order Int    @default(0)
}

model Counter {
  id     String  @id @default(cuid())
  label  String
  value  Int
  suffix String?
  color  String
  order  Int     @default(0)
}

model Project {
  id          String        @id @default(cuid())
  code        String
  slug        String        @unique
  title       String
  objective   String
  difficulty  String
  impact      String
  status      MissionStatus @default(COMPLETE)
  statusColor String
  loadout     String[]
  content     String?
  order       Int           @default(0)
}

model Skill {
  id        String @id @default(cuid())
  groupName String
  name      String
  rarity    Rarity
  level     Int
  tip       String?
  order     Int    @default(0)
}

model Achievement {
  id          String @id @default(cuid())
  year        String
  title       String
  description String
  color       String
  glow        String
  order       Int    @default(0)
}

model Social {
  id    String @id @default(cuid())
  label String
  name  String
  href  String
  order Int    @default(0)
}

model Experience {
  id          String @id @default(cuid())
  title       String
  org         String
  period      String
  description String
  order       Int    @default(0)
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String
  url         String?
  repoUrl     String?
  tags        String[]
  order       Int      @default(0)
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  tags        String[]
  coverImage  String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

/// First-party, anonymous pageview record. No PII: sessionHash is a salted
/// daily hash of IP+UA used only to estimate unique visitors.
model PageView {
  id          String   @id @default(cuid())
  path        String
  referrer    String?
  country     String?
  device      String?
  sessionHash String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

/// Singleton (id = 1) holding site-wide SEO/GEO settings, editable in admin.
model SeoSettings {
  id                 Int      @id @default(1)
  siteName           String   @default("PLAYER_01.sys")
  defaultTitle       String   @default("PLAYER_01.sys — Portfolio")
  defaultDescription String   @default("A game-themed developer portfolio: missions, skills, achievements, and a blog.")
  keywords           String[]
  ogImageUrl         String?
  twitterHandle      String?
  gscVerification    String?
  llmsTxt            String?
  updatedAt          DateTime @updatedAt
}
