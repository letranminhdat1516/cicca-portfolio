DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio?schema=public
# Generate a strong secret: `openssl rand -hex 32`  (MUST be >=16 chars; app refuses to start otherwise)
JWT_SECRET=replace-with-openssl-rand-hex-32
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
API_PORT=3001
# Comma-separated allowed CORS origins for the API
CORS_ORIGINS=http://localhost:3000
# Admin account seeded by `prisma db seed` (change in production)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123
